# Secrets for AudibleWeb (docs/design.md sec 8). Copy to .env and fill in.
# .env is gitignored -- never commit real secrets.

# GitHub PAT for the github_pages publisher (publisher.token), scoped to the
# feed repo (docs/design.md sec 6: "GitHub PAT stored in .env, scoped to repo").
GITHUB_PAT=

# Jina Reader API key for the web extractor's fallback (extraction.jina_api_key).
JINA_API_KEY=

# API key for the Kokoro TTS endpoint, if it requires one (tts.api_key).
KOKORO_API_KEY=

# API key for the optional LLM normalization endpoint (normalization.llm_api_key).
LLM_API_KEY=

# Shared secret for external API callers (server.api_key). Empty = no auth
# required (docs/design.md sec 7: "Auth: No auth by default (local network)").
API_KEY=
